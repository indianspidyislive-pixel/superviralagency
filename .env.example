# Copy this to .env and fill in real values.

# Admin login
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-please

# Telegram handle that creators get redirected to after submitting
TELEGRAM_HANDLE=Digitaljoshy

# Optional: webhook your own Telegram bot for instant notifications
